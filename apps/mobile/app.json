{
  "expo": {
    "name": "Vibe Travel",
    "slug": "vibe-travel-mobile",
    "scheme": "vibetravel",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/brand/logo-512.png",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "icon": "./assets/brand/apple-touch-icon.png",
      "infoPlist": {
        "MGLMapboxMetricsEnabledSettingShownInApp": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F7F8",
        "foregroundImage": "./assets/brand/icon-192.png"
      },
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/brand/icon-192.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-dev-client",
        {
          "launchMode": "launcher"
        }
      ],
      "@rnmapbox/maps",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
