{
  "cli": {
    "version": ">= 16.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "autoIncrement": true
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "development": {},
    "production": {
      "ios": {
        "ascAppId": "6773780596"
      },
      "android": {
        "serviceAccountKeyPath": "../../.secrets/play-store-service-account.json"
      }
    }
  }
}
